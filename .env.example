# ======================================================================
# 必填：LLM API 設定（OpenAI-Compatible Endpoint）
# ======================================================================
# 範例：NVIDIA NIM
OPENAI_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_BASE=https://integrate.api.nvidia.com/v1

# CrewAI 預設模型（可在 config/agents.yaml 中覆寫）
OPENAI_MODEL_NAME=minimaxai/minimax-m2.7

# ======================================================================
# 選用：OpenEvolve 執行參數（可在 CLI 動態指定）
# ======================================================================
# 每次 evaluate() 要跑幾個 task（預設 5）
# OPENEVOLVE_NUM_TASKS=5

# 每次 evaluate() 內部 simulation 的 hard timeout（秒，預設 900 = 15 分鐘）
# 超過會回傳 fallback fitness 讓 OpenEvolve 能繼續下一個 iteration
# OPENEVOLVE_SIM_TIMEOUT=900

# 由 OpenEvolve 自動寫入，指向當前迭代的 agents YAML 暫存路徑
# OPENEVOLVE_AGENTS_YAML=  ← 不要手動設定
